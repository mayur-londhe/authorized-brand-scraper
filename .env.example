# Private bucket used for scraper exports. Bucket names must be globally unique.
BUCKET_NAME=
AWS_REGION=us-east-2

# Prefer an AWS profile or IAM role. Use only rotated keys in an untracked .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional public/static-assets bucket; dealer exports do not use this bucket.
S3_PUBLIC_BUCKET=static-assets-01

